# Copy this file to .env to override the local Docker Compose defaults.
# Values below are examples only. Replace every password before shared use.

MYSQL_DATABASE=studentski_servis
MYSQL_USER=student_service
MYSQL_PASSWORD=replace-with-local-db-password
MYSQL_ROOT_PASSWORD=replace-with-local-root-password

BOOTSTRAP_ADMIN_USERNAME=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password

MYSQL_PORT=3306
BACKEND_PORT=8080
FRONTEND_PORT=5173

SPRING_PROFILES_ACTIVE=dev
DEMO_DATA_ENABLED=false
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional lead email SMTP. If SMTP_HOST is empty, sends are recorded as FAILED.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_AUTH=true
SMTP_STARTTLS=true
